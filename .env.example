# Example .env for Excel theme customization
# Copy this file to `.env` at project root and adjust values as needed.

# General Excel theme (default)
EXCEL_HEADER_BG=#2F4F4F
EXCEL_HEADER_FG=#FFFFFF
EXCEL_ROW_EVEN=#FFFFFF
EXCEL_ROW_ODD=#F6F6F6
EXCEL_TEAM_FILL_COLOR=#EDEDED
EXCEL_DATE_FONT_TRUE=#000000
EXCEL_DATE_FONT_FALSE=#666666
EXCEL_SUMMARY_BG=#FFD966
EXCEL_SUMMARY_FG=#000000

# Flags (true/false)
EXCEL_DISABLE_TEAM_ZEBRA=false
EXCEL_DISABLE_DATE_ZEBRA=false

# Theme specifically for Média Geral (all-records aggregated)
# Prefix: EXCEL_MEDIAS_GERAL_
EXCEL_MEDIAS_GERAL_HEADER_BG=#1F618D
EXCEL_MEDIAS_GERAL_HEADER_FG=#FFFFFF
EXCEL_MEDIAS_GERAL_ROW_EVEN=#FFFFFF
EXCEL_MEDIAS_GERAL_ROW_ODD=#F0F8FF
EXCEL_MEDIAS_GERAL_TEAM_FILL_COLOR=#DDEBF7
EXCEL_MEDIAS_GERAL_DATE_FONT_TRUE=#000000
EXCEL_MEDIAS_GERAL_DATE_FONT_FALSE=#777777
EXCEL_MEDIAS_GERAL_SUMMARY_BG=#FFB3B3
EXCEL_MEDIAS_GERAL_SUMMARY_FG=#000000
EXCEL_MEDIAS_GERAL_DISABLE_TEAM_ZEBRA=false
EXCEL_MEDIAS_GERAL_DISABLE_DATE_ZEBRA=false

# (Optional) Per-type medias themes kept for backward compatibility
EXCEL_MEDIAS_PRODUTIVAS_HEADER_BG=#2E7D32
EXCEL_MEDIAS_IMPRODUTIVAS_HEADER_BG=#B71C1C

# Output column order (comma separated, optional)
#OUTPUT_COLUMNS_ORDER=Equipe,Data Referência,TempPrep,TempPrepJornada,TempExe,TempDesl,Utilizacao,HT_Faltante

# End of example



































# Example .env for compute_and_analyze_displacement
# Configure output column order (comma-separated) and Excel theme colors (hex, without '#')
# Edit values as needed. Save this file at the project root to override defaults.

# -----------------------------------------------------------------------------
# OUTPUT_COLUMNS_ORDER
# -----------------------------------------------------------------------------
# Lista de colunas de saída na ordem desejada, separadas por vírgula.
# - Se vazia ou ausente, o sistema usa a ordem padrão implementada no código.
# - Use os nomes exatamente como aparecem nas colunas do DataFrame/CSV.
# - Exemplo: OUTPUT_COLUMNS_ORDER=Nr_Ordem,status,TempPrep,TempPrepJornada,...
OUTPUT_COLUMNS_ORDER=Nr_Ordem,status,TempPrep,TempPrepJornada,TempExe,TempDesl,HD Total,SemOrdemJornada,SemOSentreOS,Despachada,A_Caminho,No_Local,Liberada,HT Ordem,tempo_padrao

# -----------------------------------------------------------------------------
# EXCEL_* (cores e estilo)
# -----------------------------------------------------------------------------
# Valores de cor em hexadecimal (sem o caractere '#'). Podem ser em maiúsculas
# ou minúsculas, por exemplo 'FF0000' para vermelho. Se não definido, o sistema
# usará os valores padrão embutidos.

# Cor de fundo do cabeçalho (header)
EXCEL_HEADER_BG=2F5496
# Cor do texto no cabeçalho
EXCEL_HEADER_FG=FFFFFF

# Cor de fundo para linhas pares (zebra quando não houver alternância por equipe)
EXCEL_ROW_EVEN=D6E3F8
# Cor de fundo para linhas ímpares
EXCEL_ROW_ODD=FFFFFF

# Cor usada para preencher linhas alternadas por equipe (zebra por equipe)
EXCEL_TEAM_FILL_COLOR=DCE6F1

# Cor da fonte quando o toggle de data estiver 'true' (alternância por Data Referência)
EXCEL_DATE_FONT_TRUE=CC3300
# Cor da fonte quando o toggle de data estiver 'false'
EXCEL_DATE_FONT_FALSE=000000

# Cor de fundo para linhas de resumo (ex.: GERAL, MédiaTodosDias)
EXCEL_SUMMARY_BG=FFF2CC
# Cor da fonte para linhas de resumo
EXCEL_SUMMARY_FG=000000

# -----------------------------------------------------------------------------
# Exemplos/Notas
# -----------------------------------------------------------------------------
# - Para usar branco como fill da equipe: EXCEL_TEAM_FILL_COLOR=FFFFFF
# - Para usar vermelho forte na alternância de data: EXCEL_DATE_FONT_TRUE=FF0000
# - Depois de editar este arquivo, reexecute o pipeline (python src/main.py)
#   para que as mudanças sejam aplicadas ao próximo arquivo Excel gerado.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# EXCEL_MEDIAS_* (opções específicas para as planilhas de médias - genérico)
# -----------------------------------------------------------------------------
# Variáveis com prefixo EXCEL_MEDIAS_* aplicam-se a todas as planilhas de médias
# (produtivas e improdutivas) a menos que existam variantes mais específicas
# (EXCEL_MEDIAS_PRODUTIVAS_* ou EXCEL_MEDIAS_IMPRODUTIVAS_*).

# Desabilita zebra por equipe nas planilhas de médias (true/false)
EXCEL_MEDIAS_DISABLE_TEAM_ZEBRA=false
# Desabilita zebra por data nas planilhas de médias (true/false)
EXCEL_MEDIAS_DISABLE_DATE_ZEBRA=false

# Exemplo de override para todas as medias
#EXCEL_MEDIAS_TEAM_FILL_COLOR=FFFFFF
#EXCEL_MEDIAS_DATE_FONT_TRUE=FF0000

# -----------------------------------------------------------------------------
# EXCEL_MEDIAS_PRODUTIVAS_* (opções específicas para medias produtivas)
# -----------------------------------------------------------------------------
# Exemplos:
# EXCEL_MEDIAS_PRODUTIVAS_DISABLE_TEAM_ZEBRA=true
# EXCEL_MEDIAS_PRODUTIVAS_TEAM_FILL_COLOR=FFFFFF
# EXCEL_MEDIAS_PRODUTIVAS_DATE_FONT_TRUE=FF0000

# -----------------------------------------------------------------------------
# EXCEL_MEDIAS_IMPRODUTIVAS_* (opções específicas para medias improdutivas)
# -----------------------------------------------------------------------------
# Exemplos:
# EXCEL_MEDIAS_IMPRODUTIVAS_DISABLE_TEAM_ZEBRA=true
# EXCEL_MEDIAS_IMPRODUTIVAS_DISABLE_DATE_ZEBRA=true
# EXCEL_MEDIAS_IMPRODUTIVAS_ROW_EVEN=F0F0F0

# -----------------------------------------------------------------------------
# EXCEL_DESLOCAMENTO_* (opções para a planilha deslocamento_calculado)
# -----------------------------------------------------------------------------
# Variáveis com prefixo EXCEL_DESLOCAMENTO_* aplicam-se apenas à aba/arquivo de
# deslocamento_calculado. Use-as para manter os dois zebrados e regras próprias.

# Exemplo: manter zebra por equipe/data na planilha de deslocamento
#EXCEL_DESLOCAMENTO_DISABLE_TEAM_ZEBRA=false
#EXCEL_DESLOCAMENTO_DISABLE_DATE_ZEBRA=false
# EXCEL_DESLOCAMENTO_TEAM_FILL_COLOR=C0D9F5
