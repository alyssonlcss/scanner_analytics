{
  "name": "scanner-analytics-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "npm run port:free && npm run edge:debug",
    "port:free": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/free-port.ps1 -Port 3000",
    "dev": "tsc -p tsconfig.json && node dist/main.js",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "check": "tsc --noEmit -p tsconfig.json",
    "edge:debug": "powershell -ExecutionPolicy Bypass -File ./scripts/start-edge-debug.ps1"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.0",
    "csv-parse": "^6.2.1",
    "dotenv": "^16.5.0",
    "fastify": "^5.2.1",
    "puppeteer": "^24.7.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.22.4",
    "typescript": "^5.8.2"
  }
}
